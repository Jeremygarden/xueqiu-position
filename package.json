{
  "name": "xueqiu-position",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "uni-app Vue3 mini-program for tracking Xueqiu portfolio positions with technical indicators (MACD/RSI/BB) and community highlights.",
  "scripts": {
    "dev:mp-weixin": "uni -p mp-weixin",
    "build:mp-weixin": "uni build -p mp-weixin",
    "dev:h5": "uni -p h5",
    "build:h5": "uni build -p h5",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dcloudio/uni-app": "vue3",
    "@dcloudio/uni-ui": "^1.5.6",
    "pinia": "^2.1.7",
    "uview-plus": "^3.4.31",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.14",
    "@dcloudio/vite-plugin-uni": "vue3",
    "@vitejs/plugin-vue": "^6.0.0",
    "sass": "^1.75.0",
    "vite": "7.3.3",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9"
  }
}
